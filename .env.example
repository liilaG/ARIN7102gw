# ============================================================================
# ARIN Query Intelligence 环境变量配置示例
# ============================================================================
# 使用方法：
# 1. 复制本文件为 .env: cp .env.example .env
# 2. 填写你的 API 密钥和配置
# 3. 确保 .env 已添加到 .gitignore（避免提交敏感信息）
# ============================================================================

# ----------------------------------------------------------------------------
# 必需的 API 密钥
# ----------------------------------------------------------------------------

# Tushare Token
# 获取地址：https://tushare.pro/register
# 说明：用于获取 A 股行情、财务指标、新闻等结构化数据
# 优先级：Tushare > AKShare（无 token 时自动 fallback 到 AKShare）
TUSHARE_TOKEN=your_tushare_token_here

# ----------------------------------------------------------------------------
# 可选的外部服务配置
# ----------------------------------------------------------------------------

# PostgreSQL DSN（可选）
# 说明：生产环境可接 PostgreSQL 存储文档库和结构化数据
# 格式：postgresql://user:password@host:port/database
# 示例：postgresql://postgres:password@localhost:5432/arin_db
QI_POSTGRES_DSN=

# ----------------------------------------------------------------------------
# Live 数据源开关
# ----------------------------------------------------------------------------

# 开启实时行情数据（默认 false）
QI_USE_LIVE_MARKET=false

# 开启实时新闻数据（默认跟随 QI_USE_LIVE_MARKET）
QI_USE_LIVE_NEWS=false

# 开启实时公告数据（默认跟随 QI_USE_LIVE_MARKET）
QI_USE_LIVE_ANNOUNCEMENT=false

# 开启实时宏观指标数据（默认 false）
QI_USE_LIVE_MACRO=false

# 开启 PostgreSQL 检索（默认 false）
QI_USE_POSTGRES_RETRIEVAL=false

# ----------------------------------------------------------------------------
# 数据源配置（可选）
# ----------------------------------------------------------------------------

# 巨潮公告查询 URL（默认值通常无需修改）
CNINFO_ANNOUNCEMENT_URL=https://www.cninfo.com.cn/new/hisAnnouncement/query

# 巨潮 PDF 静态文件 Base URL（默认值通常无需修改）
CNINFO_STATIC_BASE=https://static.cninfo.com.cn/

# ----------------------------------------------------------------------------
# 性能和超时配置
# ----------------------------------------------------------------------------

# HTTP 请求超时时间（秒，默认 15）
QI_HTTP_TIMEOUT_SECONDS=15

# ----------------------------------------------------------------------------
# 模型和数据路径配置
# ----------------------------------------------------------------------------

# 模型文件目录（默认 models）
QI_MODELS_DIR=models

# API artifacts 输出目录（默认 outputs/query_intelligence）
QI_API_OUTPUT_DIR=outputs/query_intelligence

# ----------------------------------------------------------------------------
# 训练相关配置（仅在训练模型时需要）
# ----------------------------------------------------------------------------

# 训练 manifest 文件路径
QI_TRAINING_MANIFEST=

# 旧版训练数据集路径（已废弃，建议使用 manifest）
QI_TRAINING_DATASET=

# 启用外部公开数据集同步（默认 false）
# 注意：同步数据集需要网络连接和较长时间
QI_ENABLE_EXTERNAL_DATA=false

# 数据集白名单（逗号分隔）
# 示例：finfe,t2ranking,fir_bench_reports
QI_DATASET_ALLOWLIST=

# 构建资产时启用翻译（默认 false）
QI_ENABLE_TRANSLATION=false

# 强制刷新数据（默认 false）
QI_FORCE_REFRESH_DATA=false

# ----------------------------------------------------------------------------
# 运行时资产路径覆盖（高级配置，通常无需修改）
# ----------------------------------------------------------------------------

# 实体主表路径
QI_ENTITY_MASTER_PATH=

# Alias 表路径
QI_ALIAS_TABLE_PATH=

# 文档库路径
QI_DOCUMENTS_PATH=

# ============================================================================
# 快速启动示例
# ============================================================================
#
# 1. 基础运行（使用内置 seed 数据）：
#    python manual_test/run_manual_query.py --query "你觉得中国平安怎么样？"
#
# 2. 开启实时数据（需要 TUSHARE_TOKEN）：
#    QI_USE_LIVE_MARKET=1 QI_USE_LIVE_NEWS=1 QI_USE_LIVE_ANNOUNCEMENT=1 \
#    python manual_test/run_manual_query.py --query "你觉得中国平安怎么样？"
#
# 3. 启动 FastAPI 服务：
#    uvicorn query_intelligence.api.app:create_app --factory --host 0.0.0.0 --port 8000
#
# ============================================================================
